{
  "name": "@webdesserts/ui",
  "version": "2.0.0-alpha.1",
  "description": "Shared UI components and design tokens for webdesserts projects",
  "author": "Michael C Mullins",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens": "./src/tokens/semantic.css",
    "./presets/*": "./src/tokens/presets/*"
  },
  "files": [
    "dist",
    "src/tokens"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:update": "vitest --update"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "motion": "^12.0.0"
  },
  "peerDependenciesMeta": {
    "motion": {
      "optional": true
    }
  },
  "devDependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "clsx": "^2.0.0",
    "motion": "^12.38.0",
    "playwright": "^1.50.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0",
    "vitest-browser-react": "^2.1.0"
  }
}
